# This is gitignore

# Dependency directories
node_modules/
client/node_modules/
server/node_modules/

# Local configuration and environment variables (highly sensitive)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Production builds
client/dist/

# Uploads and temporary directories
server/uploads/*
!server/uploads/.gitkeep
server/tmp/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System and IDE folders
.vscode/
.idea/
.DS_Store
Thumbs.db
